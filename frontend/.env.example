# Backend API — browser MUST use the storefront origin so refresh_token cookies work.
# Next.js rewrites /api/v1/* → BACKEND_PROXY_URL (see next.config.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3102/api/v1
BACKEND_PROXY_URL=http://127.0.0.1:3000

# Mobile/LAN `next dev` — allow every host you open on phone for HMR + `/_next/*`.
# Use the Network IP from `npm run dev`. If DHCP changes (e.g. 192.168.1.4 → .38), comma-separate ALL IPs you use.
ALLOWED_DEV_ORIGINS=192.168.1.38,192.168.1.4

# Server-side direct API base for RSC/server actions (bypasses Next rewrite)
INTERNAL_API_BASE_URL=http://127.0.0.1:3000/api/v1

# Cloudflare Turnstile — site key is public; secret stays on backend TURNSTILE_SECRET_KEY only
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADduYluQ020Mz8nm
# NEXT_PUBLIC_TURNSTILE_ENFORCE_IN_DEV=true

# Local dev only (Next NODE_ENV=development) — shows OTP hint on admin login
# ⚠ NEVER copy to production; guarded at runtime by NODE_ENV check on both sides
# NEXT_PUBLIC_AUTH_DEV_BYPASS=true
# NEXT_PUBLIC_AUTH_DEV_OTP=000000

# Show JSON mutation dev surfaces in admin nav (/admin/catalog-write, /admin/mutations)
# NEXT_PUBLIC_ADMIN_DEV_TOOLS=true

# Storefront
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3102
NEXT_PUBLIC_STORE_NAME="Sri Sai Baba Ghee Sweets"

# Payment — public Razorpay key only (never the secret)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# COD availability is controlled by Admin → Settings → COD (GET /store/config), not a frontend env flag.

# Analytics (production only)
# Reserved for future analytics integration (not wired in app yet):
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=

# Image CDN — production: match Ops R2_PUBLIC_BASE_URL (SBGS: https://cdn.srisaibabasweets.com)
# Local dev (MEDIA_STORAGE_PROVIDER=local): http://localhost:3102 (rewrites to API media routes)
NEXT_PUBLIC_IMAGE_CDN_URL=

# GST invoicing — legacy; admin panels use GET /store/config.gstInvoicingEnabled
# NEXT_PUBLIC_FEATURE_GST_INVOICING_ENABLED=true

# Storefront module flags — runtime via GET /store/config (ISR 60s). Legacy build-time keys:
# NEXT_PUBLIC_FEATURE_WISHLIST_ENABLED=true

# Coupons / reviews — must match backend FEATURE_* flags (default off)
# NEXT_PUBLIC_FEATURE_COUPONS_ENABLED=true
# NEXT_PUBLIC_FEATURE_REVIEWS_ENABLED=true

# Ops metrics snapshot (server-only RSC fetch to GET /api/v1/ops/metrics)
OPS_METRICS_TOKEN=

# Ops console uses browser cookie session (ops_session) — no API keys in the browser.

# Optional: protect /ops pages with HTTP Basic Auth (recommended in shared/staging/prod)
OPS_UI_BASIC_AUTH_USERNAME=
OPS_UI_BASIC_AUTH_PASSWORD=
