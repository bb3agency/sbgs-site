# VPS production — copy to .env.production.local on the server
#   cp .env.production.example .env.production.local
# Never commit the filled file.

CLIENT_ID=sbgs
STOREFRONT_PORT=3102

# Browser must use the public same-origin API prefix (refresh_token cookie: Path=/api/v1).
NEXT_PUBLIC_API_BASE_URL=https://srisaibabasweets.com/api/v1
INTERNAL_API_BASE_URL=http://127.0.0.1:3002/api/v1
NEXT_PUBLIC_STOREFRONT_URL=https://srisaibabasweets.com
NEXT_PUBLIC_STORE_NAME="Sri Sai Baba Ghee Sweets"

NEXT_PUBLIC_RAZORPAY_KEY_ID=
# COD availability is controlled by Admin → Settings → COD (GET /store/config).

# GST invoicing — legacy build-time flag; admin GST panels use GET /store/config.gstInvoicingEnabled
# NEXT_PUBLIC_FEATURE_GST_INVOICING_ENABLED=true

# Storefront module flags — runtime via GET /store/config (no redeploy when backend FEATURE_* changes)
# NEXT_PUBLIC_FEATURE_* keys below are legacy only — do not use for new storefront work
# NEXT_PUBLIC_FEATURE_COUPONS_ENABLED=true
# NEXT_PUBLIC_FEATURE_REVIEWS_ENABLED=true
# NEXT_PUBLIC_FEATURE_WISHLIST_ENABLED=true

# Cloudflare Turnstile (public site key — secret on backend .env only)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADduYluQ020Mz8nm

# Ops UI protection (recommended on shared/staging/production VPS)
OPS_UI_BASIC_AUTH_USERNAME=
OPS_UI_BASIC_AUTH_PASSWORD=

# Server-only ops metrics (optional — match backend OPS_METRICS_TOKEN if used)
OPS_METRICS_TOKEN=

# Product images — Cloudflare R2 custom domain (must match Ops R2_PUBLIC_BASE_URL)
NEXT_PUBLIC_IMAGE_CDN_URL=https://cdn.srisaibabasweets.com
