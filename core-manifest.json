{
  "$comment": "Declares which paths are platform CORE (must stay in sync with the pinned template tag) vs CLIENT (design/extension — allowed to differ). Drives backend/scripts/check-core-drift.sh + sync-core.mjs. NOTE: core TEST files (*.test.ts/*.spec.ts) and the committed .env.example ARE core — they sync automatically with the source they cover, so a core change that alters test expectations or adds an env key propagates to every client without manual hand-delivery. Real secret env files (.env, .env.*.local) are gitignored/untracked and are never synced regardless. Client-specific tests belong under the client-extension paths (src/modules/client/**, app/(client)/**), which stay excluded. See backend/docs/PLATFORM_VERSIONING_AND_SYNC_GUIDE.md §7.",
  "version": 1,
  "backendCore": {
    "include": [
      "backend/src/**",
      "backend/prisma/schema.prisma",
      "backend/prisma/migrations/**",
      "backend/scripts/**",
      "backend/queues/**",
      "backend/tsconfig.json",
      "backend/TRD.md",
      "backend/.env.example",
      "core-manifest.json",
      "core-purity-denylist.txt"
    ],
    "exclude": [
      "backend/.env",
      "backend/.env.local",
      "backend/.env.*.local",
      "backend/docs/clients/**",
      "backend/src/modules/client/**",
      "backend/src/modules/client/**/*.test.ts",
      "backend/src/modules/notifications/templates/**"
    ]
  },
  "frontendCore": {
    "include": [
      "frontend/lib/**",
      "frontend/actions/**",
      "frontend/components/ui/**",
      "frontend/components/product/**",
      "frontend/components/cart/**",
      "frontend/components/checkout/**",
      "frontend/components/layout/**",
      "frontend/components/admin/**",
      "frontend/hooks/**",
      "frontend/stores/**",
      "frontend/types/**",
      "frontend/app/**/page.tsx",
      "frontend/app/**/layout.tsx",
      "frontend/next.config.ts",
      "frontend/middleware.ts"
    ],
    "exclude": [
      "frontend/app/globals.css",
      "frontend/lib/fonts.ts",
      "frontend/lib/constants.ts",
      "frontend/lib/content.ts",
      "frontend/public/**",
      "frontend/components/marketing/**",
      "frontend/components/storefront/home/**",
      "frontend/components/layout/Footer.tsx",
      "frontend/components/client/**",
      "frontend/app/(client)/**",
      "frontend/app/(storefront)/page.tsx",
      "frontend/app/(storefront)/about/**",
      "frontend/app/(storefront)/privacy/**",
      "frontend/app/(storefront)/terms/**",
      "frontend/app/(storefront)/returns/**",
      "frontend/app/(storefront)/shipping/**",
      "frontend/components/client/**/*.test.ts",
      "frontend/components/client/**/*.test.tsx",
      "frontend/app/(client)/**/*.test.ts",
      "frontend/app/(client)/**/*.test.tsx",
      "frontend/.env*"
    ]
  },
  "designLayer": {
    "$comment": "Per-client. Never overwritten by core sync (also protected via .gitattributes merge=ours).",
    "paths": [
      "frontend/app/globals.css",
      "frontend/lib/fonts.ts",
      "frontend/lib/constants.ts",
      "frontend/lib/content.ts",
      "frontend/public/**"
    ]
  }
}
