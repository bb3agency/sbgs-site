ners.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eFor international shipping inquiries, contact our support. Our clients within Hyderabad, India can get instant delivery using \u003c\/span\u003e\u003cspan style=\"color: rgb(137, 6, 12);\"\u003e\u003ca href=\"https:\/\/www.swiggy.com\/menu\/2085?source=sharing\" style=\"color: rgb(137, 6, 12);\"\u003eSwiggy\u003c\/a\u003e\u003c\/span\u003e\u003cspan\u003e or \u003c\/span\u003e\u003cspan style=\"color: rgb(137, 6, 12);\"\u003e\u003ca href=\"https:\/\/zomato.onelink.me\/xqzv\/h1s29802\" style=\"color: rgb(137, 6, 12);\"\u003eZomato\u003c\/a\u003e\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eFor a free tasting and a true gourmet experience, visit Dadu’s near you\u003c\/span\u003e\u003c\/p\u003e","brand":"Dadu’s (Indian Mithai)","offers":[{"title":"250 Gms","offer_id":45343264375064,"sku":null,"price":340.0,"currency_code":"INR","in_stock":true},{"title":"500 Gms","offer_id":47803108131096,"sku":null,"price":680.0,"currency_code":"INR","in_stock":true},{"title":"1 Kg","offer_id":47803108163864,"sku":null,"price":1360.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0722\/9692\/3416\/files\/KhovaGujiya_698db37a-b9ff-46f6-911b-74cf8449f8ae.jpg?v=1771672016"},{"product_id":"moongdal-burfi","title":"Moongdal Burfi","description":"\u003c!----\u003e","brand":"Dadu’s (Indian Mithai)","offers":[{"title":"250 Gms","offer_id":45343649530136,"sku":null,"price":335.0,"currency_code":"INR","in_stock":true},{"title":"500 Gms","offer_id":45343649562904,"sku":null,"price":670.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0722\/9692\/3416\/files\/MoongdalBurfi3.jpg?v=1770632147"},{"product_id":"ragi-laddu","title":"Ragi Laddu","description":"","brand":"Dadu’s (Indian Mithai)","offers":[{"title":"250 Gms","offer_id":45370789986584,"sku":null,"price":305.0,"currency_code":"INR","in_stock":t