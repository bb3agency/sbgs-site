# ==============================================================================
# PRODUCTION SETUP — TWO-PHASE MODEL
#
# PHASE 1 — Set in .env BEFORE first deploy (bootstrap-only, app won't start without these):
#   NODE_ENV, DATABASE_URL, REDIS_URL, OPS_DB_ENCRYPTION_KEY, JWT_SECRET,
#   JWT_REFRESH_SECRET, CLIENT_ID, OPS_COOKIE_SECRET, AUDIT_ANCHOR_SECRET,
#   STOREFRONT_URL, ADMIN_URL, ADMIN_ALERT_EMAIL
#   + RESEND_API_KEY + RESEND_FROM (needed once to send the first ops invite email)
#
# PHASE 2 — Set via Ops UI → Config AFTER first ops login (stored encrypted in DB):
#   All payment, shipping, notification provider keys, webhook tokens, allowlists,
#   circuit-breaker thresholds, ops security keys.
#   After first login, RESEND_API_KEY/FROM can also be rotated via Ops UI.
#
# See: docs/PRODUCTION_FIRST_DEPLOY_CHECKLIST.md for step-by-step guide.
#
# ENV CLASSIFICATION
# BOOTSTRAP:    Required in .env before boot. Never loaded from DB.
# RUNTIME-ONLY: Set in .env. Not managed via Ops UI.
# OPS-MANAGED:  Commented stubs below. Configure via Ops UI after first boot.
# ==============================================================================

# ── Core bootstrap ────────────────────────────────────────────────────────────
# PRODUCTION: change to production. Controls plaintext OTP storage (dev/test only) and other guards.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CLIENT_ID=ecomtemplate

# ── Docker Compose convenience (VPS: REQUIRED. Local dev: leave commented) ──
# On the VPS these two lines MUST be uncommented and the value set to your
# CLIENT_ID. Without them, any manual `docker compose ...` command from this
# directory misbehaves in two well-known ways:
#
#   1. The `postgres` service from the base docker-compose.yml tries to
#      start and fails with "failed to bind host port 0.0.0.0:5432/tcp:
#      address already in use" (host Postgres is already on 5432).
#   2. The project name defaults to the directory basename ("backend"),
#      so subsequent `docker compose ...` commands lose track of containers
#      created with a custom -p flag, leaving "Dead" tombstones behind that
#      keep producing scary "No such container" errors on every up/down.
#
# Set both:
#   COMPOSE_FILE          — merges docker-compose.prod.yml over the base file.
#                           The prod overlay hides the in-compose postgres
#                           service behind a profile and removes it from
#                           backend/workers' depends_on.
#   COMPOSE_PROJECT_NAME  — pins the project name so every command refers to
#                           the same set of containers. MUST match CLIENT_ID.
#
# CD (backend/scripts/vps-deploy.sh) passes -f/-p explicitly and works
# regardless, but these settings are essential for manual ops (incident
# debugging, log tailing, container exec, etc.).
#
# Recovery if you've already accumulated Dead containers:
#   bash backend/scripts/cleanup-stale-compose-state.sh "$CLIENT_ID"
#
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
# COMPOSE_PROJECT_NAME=ecomtemplate   # set to the same value as CLIENT_ID

# ── Nginx config auto-reload during CD (VPS-ONLY, optional but recommended) ─
# When set to "1", scripts/vps-deploy.sh will diff nginx/client.conf.template
# against the live /etc/nginx/sites-available/<CLIENT_ID>.conf and, if they
# differ, copy the template into place, run `nginx -t`, and reload nginx.
# Failure of the test aborts the deploy without reloading.
#
# Requires passwordless sudo for the CI runner user on:
#   cp /var/www/.../nginx/client.conf.template /etc/nginx/sites-available/<id>.conf
#   nginx -t
#   systemctl reload nginx
#
# Leave unset to keep the deploy script in "warn only" mode — it will log a
# drift warning and you can sync manually:
#   sudo cp nginx/client.conf.template /etc/nginx/sites-available/<id>.conf \
#     && sudo nginx -t && sudo systemctl reload nginx
# NGINX_AUTO_RELOAD=0

# Infrastructure — Docker Compose postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecom_template
POSTGRES_PORT=5432
# DATABASE_URL: bootstrap-only. Must be set before DB-backed Ops config can load.
# Docker: postgresql://postgres:postgres@postgres:5432/ecom_template
# Local:  postgresql://postgres:postgres@localhost:5432/ecom_template
# URL-encode special chars in password (@ → %40, # → %23)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecom_template
# REDIS_URL: bootstrap-only for initial Redis connection.
# Docker (in Compose): redis://:password@redis:6379
# Local host dev (dev-up.cmd): redis://:password@localhost:6379
# IMPORTANT: when REDIS_PASSWORD is set, embed it in REDIS_URL (redis://:yourpassword@host:6379).
# A password in REDIS_PASSWORD without one in REDIS_URL causes auth failures and ECONNRESET loops.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# REDIS_URL_LOCAL: used by CI scripts (admin-contract-check, etc.) that run on the
# host while the backend runs in Docker Compose. Set this to the port-mapped address
# so scripts can reach Redis without the Docker service-name hostname.
# Example: redis://:password@localhost:6379
# REDIS_URL_LOCAL=

STOREFRONT_URL=https://client1.com
# Required in production-like profiles — boot fails if missing (password-reset email links).
ADMIN_URL=https://client1.com

# Auth (bootstrap)
JWT_SECRET=replace_with_64_char_secret
JWT_REFRESH_SECRET=replace_with_64_char_refresh_secret

# OPS_DB_ENCRYPTION_KEY: bootstrap-only. Never loaded from DB. No fallback.
OPS_DB_ENCRYPTION_KEY=replace_with_ops_db_encryption_key
OPS_DB_ENCRYPTION_KEY_VERSION=1

# Alert recipient when DB overlay is unavailable (env-only fallback)
ADMIN_ALERT_EMAIL=admin@example.com

# Audit tamper-evident chain anchor
AUDIT_ANCHOR_SECRET=replace_with_audit_anchor_secret

# ── Email bootstrap (required for first ops invite — Phase 1) ────────────────
# Set these before running: node scripts/ops-newuser.mjs
# After first ops user is created and logged in, manage via Ops UI → Config.
RESEND_API_KEY=replace_with_resend_key
RESEND_FROM=Ecom Store <noreply@example.com>

# Cloudflare Turnstile — ⚠ REQUIRED in production (startup rejects missing key unless TURNSTILE_SKIP_PRODUCTION_CHECK=true)
# Pairs with NEXT_PUBLIC_TURNSTILE_SITE_KEY on the storefront. Copy secret from docs/clients/sbgs/VPS_INPUTS.md (gitignored) into backend/.env
# TURNSTILE_SECRET_KEY=
# TURNSTILE_ENFORCE_IN_DEV=true    # Uncomment to test Turnstile locally
# TURNSTILE_SKIP_PRODUCTION_CHECK=true  # ONLY use when intentionally running prod without Turnstile

# Development/test ONLY — required for fixed OTP 000000 during local admin login
# ⚠ NEVER set in production (startup will reject it when NODE_ENV=production)
# AUTH_DEV_BYPASS=true
# AUTH_DEV_OTP=000000

# Redis key derivation (optional — defaults to JWT_SECRET)
REDIS_KEY_PEPPER=

# ── Feature flags (RUNTIME-ONLY) ─────────────────────────────────────────────
FEATURE_COUPONS_ENABLED=false
FEATURE_REVIEWS_ENABLED=false
FEATURE_WISHLIST_ENABLED=false
FEATURE_GST_INVOICING_ENABLED=true
# Set to true when your frontend expects { success, data, meta? } envelope format.
FEATURE_RESPONSE_ENVELOPE_ENABLED=false

# ── Runtime tuning (RUNTIME-ONLY) ────────────────────────────────────────────
CART_RESERVATION_TTL_MINUTES=20
LOAD_SHED_MODE=normal
ENABLE_VERBOSE_VALIDATION_ERRORS=false
HEALTH_QUEUE_STALE_WAITING_SECONDS=300

# Checkout risk velocity (optional)
RISK_VELOCITY_ENABLED=false
RISK_PAYMENT_INIT_MAX_PER_HOUR=30

# Flash-sale / hot-SKU admission control (leave empty to disable)
HOT_SKU_VARIANT_IDS=
HOT_SKU_ADMISSION_BUDGET_PER_MINUTE=120
HOT_SKU_USER_RESERVE_CAP=2
HOT_SKU_COOLDOWN_SECONDS=15
HOT_SKU_SHARD_COUNT=8

# Idempotency scope HMAC (optional — falls back to JWT_SECRET)
IDEMPOTENCY_SCOPE_SECRET=

# Admin IAM (runtime defaults — override via Ops UI for production hardening)
ADMIN_DEFAULT_PERMISSIONS=
ADMIN_SCOPE_ENFORCEMENT=true
ALLOW_ADMIN_SCOPE_BYPASS=false

# Seller profile: DB-backed via StoreSettings (storeName, sellerAddress, gstin, etc.)
# Configure in Admin → Settings or via Ops API. Do NOT set env fallbacks here.

# ── OpenTelemetry (RUNTIME-ONLY) ──────────────────────────────────────────────
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=ecom-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ── Reconciliation auto-heal (RUNTIME-ONLY) ───────────────────────────────────
# Leave unset to enable all four safe types. Empty string = disable all (manual review only).
RECONCILIATION_AUTO_HEAL_ISSUES=

# ── Process restart payment drain (RUNTIME-ONLY) ──────────────────────────────
# Maximum time (ms) the scheduled-process-restart job will wait for all
# PENDING_PAYMENT orders to reach a terminal state before proceeding with the
# restart. If the timeout fires, a TechnicalFailureAlert is sent to ops/admin
# and the restart proceeds anyway.
# Default: 300000 (5 minutes). Set lower (e.g. 10000) for staging/test environments.
# RESTART_PAYMENT_DRAIN_TIMEOUT_MS=300000

# ── Maintenance read-side self-heal (RUNTIME-ONLY) ────────────────────────────
# Tier 1 — BullMQ-aware fast-promote grace. When a maintenance window is past
# `pendingUntil + MAINTENANCE_FAST_PROMOTE_GRACE_MS`, the read path asks BullMQ
# whether the maintenance-activation job exists for the current window. If
# the probe reports 'missing' (worker offline / queue plugin failed at boot /
# Redis evicted the delayed job), the state is promoted immediately to
# phase=active. If it reports 'present', the worker is healthy and on it —
# fall through to the long-grace fallback (MAINTENANCE_ACTIVATION_GRACE_MS).
# Default: 15000 (15s). Set to 0 in staging for instant cutover. Keep at the
# default in production to absorb BullMQ delayed-job polling jitter.
# MAINTENANCE_FAST_PROMOTE_GRACE_MS=15000

# Tier 2 — long-grace fallback. The absolute last-resort guarantee that the
# system cannot get stuck in 'pending' even when BullMQ probes can't answer.
# Must be larger than your worst-case worker drain (queue + payment timeouts
# combined) plus a small cushion for BullMQ delayed-job polling jitter, so
# the fallback never races a healthy worker mid-drain.
# Default: 420000 (7 minutes). Lower only if you've tuned the worker drains.
# MAINTENANCE_ACTIVATION_GRACE_MS=420000

# ==============================================================================
# OPS-MANAGED KEYS (PHASE 2) — configure via Ops UI → Config after first login.
# These are stored encrypted in OpsConfigSecret (DB) and applied at startup.
# The commented stubs below are for documentation and drift-check purposes only.
# EXCEPTION: RESEND_API_KEY + RESEND_FROM must also be set in Phase 1 (above)
#            for the initial ops invite email (ops-newuser.mjs). After that,
#            they can be managed exclusively via Ops UI.
# ==============================================================================

# ── Ops security (Ops UI → Config) ───────────────────────────────────────────
# OPS_METRICS_ALLOWLIST=
OPS_METRICS_TOKEN=

# ── Ops browser login session (httpOnly cookie) ───────────────────────────────
# OPS_COOKIE_SECRET: secret used to sign ops_session cookies. Required in production.
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPS_COOKIE_SECRET=replace_with_32_byte_hex_secret
# OPS_BROWSER_SESSION_TTL_SECONDS: how long the browser session cookie is valid (default: 3600 = 1 hour)
OPS_BROWSER_SESSION_TTL_SECONDS=3600
# OPS_LOGIN_OTP_TTL_SECONDS: how long the login OTP is valid (default: 300 = 5 minutes)
OPS_LOGIN_OTP_TTL_SECONDS=300

# REPLAY_APPROVAL_TOKEN=
# REPLAY_AUDIT_RETENTION_DAYS=90

# ── Webhook defense (Ops UI → Config) ────────────────────────────────────────
# TRUSTED_PROXY_ALLOWLIST_CIDR=

# ── Payments (Ops UI → Config) ───────────────────────────────────────────────
# PAYMENT_PROVIDER=razorpay
# PAYMENT_PROVIDER_FAILOVER_ENABLED=false
# PAYMENT_CB_FAILURE_THRESHOLD=5
# PAYMENT_CB_COOLDOWN_MS=30000
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_WEBHOOK_SECRET_OLD=
# RAZORPAY_WEBHOOK_ALLOWLIST_CIDR=
# RAZORPAY_WEBHOOK_MAX_SKEW_SECONDS=300

# ── Shipping (Ops UI → Config) ────────────────────────────────────────────────
# SHIPPING_PROVIDER=delhivery
# SHIPPING_PROVIDER_FAILOVER_ENABLED=false
# SHIPPING_CB_FAILURE_THRESHOLD=5
# SHIPPING_CB_COOLDOWN_MS=30000
# SHIPPING_WEBHOOK_ALLOWLIST_CIDR=
# Numeric fallback HSN for carrier payloads when products omit hsnCode (Shiprocket requires digits).
# DEFAULT_SHIPPING_HSN=2106
# Delhivery:
# DELHIVERY_API_KEY=
# DELHIVERY_BASE_URL=https://track.delhivery.com
# DELHIVERY_PICKUP_LOCATION=
# DELHIVERY_PICKUP_PINCODE=
# DELHIVERY_SELLER_NAME=
# DELHIVERY_SELLER_ADDRESS=
# DELHIVERY_SELLER_CITY=
# DELHIVERY_SELLER_STATE=
# DELHIVERY_SELLER_PHONE=
# DELHIVERY_WEBHOOK_TOKEN=
# DELHIVERY_WEBHOOK_ALLOWLIST_CIDR=
# DELHIVERY_WEBHOOK_MAX_SKEW_SECONDS=300
# Shiprocket:
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external
# SHIPROCKET_PICKUP_PINCODE=
# SHIPROCKET_PICKUP_LOCATION=Primary
# SHIPROCKET_WEBHOOK_TOKEN=
# SHIPROCKET_WEBHOOK_ALLOWLIST_CIDR=
# SHIPROCKET_WEBHOOK_MAX_SKEW_SECONDS=300

# ── Notifications (Ops UI → Config) ──────────────────────────────────────────
# NOTE: RESEND_API_KEY + RESEND_FROM must ALSO be set as live (non-commented) values
# in the BOOTSTRAP section above for the initial ops invite (node scripts/ops-newuser.mjs).
# After first ops login, rotate/manage these via Ops UI only.
# NOTIFY_EMAIL_ENABLED=true
# NOTIFY_SMS_ENABLED=false
# NOTIFY_WHATSAPP_ENABLED=false
# EMAIL_PROVIDER=resend
# SMS_PROVIDER=msg91
# RESEND_API_KEY=
# RESEND_FROM=
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=
# MSG91_ROUTE=
# FAST2SMS_API_KEY=
# META_WHATSAPP_ACCESS_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_API_VERSION=v19.0
# META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# META_WHATSAPP_APP_SECRET=

# ── Invoice storage (Ops UI → Config) ────────────────────────────────────────
# INVOICE_STORAGE_ROOT=/var/www/client/storage/invoices

# Product images — Ops UI → Product Media (Cloudflare R2); DB overlay, not bootstrap values:
# MEDIA_STORAGE_PROVIDER=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=
# R2_ENDPOINT=
# MEDIA_STORAGE_ROOT=
# MEDIA_CDN_BASE_URL=
# PUBLIC_STORE_URL=https://shop.yourdomain.com

# ── CI / contract-check scripts ──────────────────────────────────────────────
# Used by: scripts/admin-contract-check.js, scripts/deep-endpoint-smoke.js
# Set these to a real seeded admin account so contract checks can authenticate.
# ADMIN_EMAIL defaults to admin@example.com and ADMIN_PASSWORD to Admin@12345
# if not set — override here to match your actual seeded admin credentials.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345
# BASE_URL: target server for contract/smoke scripts. Defaults to http://127.0.0.1:3000
# BASE_URL=http://127.0.0.1:3000
