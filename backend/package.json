{
  "name": "ecom-backend-template",
  "version": "0.1.1",
  "private": true,
  "description": "Production-grade modular monolith e-commerce backend template",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx --env-file .env watch src/main.ts",
    "dev:workers": "tsx --env-file .env watch queues/workers/index.ts",
    "dev:e2e": "scripts\\dev-up.cmd",
    "dev:e2e:workers": "scripts\\dev-up-workers.cmd",
    "build": "node scripts/build.js",
    "start": "node bootstrap-backend.js",
    "start:workers": "node bootstrap-workers.js",
    "typecheck": "node scripts/typecheck.js",
    "verify:bootstrap-env": "node scripts/verify-client-bootstrap-env.mjs",
    "verify:r2-media": "node scripts/verify-r2-media-config.mjs",
    "verify:vps-preflight": "node scripts/verify-vps-deploy-preflight.mjs",
    "verify:integration": "node scripts/verify-integration-readiness.mjs",
    "lint": "node scripts/lint.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:unit:coverage": "vitest run -c vitest.config.ts --coverage",
    "coverage:ratchet": "node scripts/coverage-ratchet-check.js",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:security": "vitest run -c vitest.security.config.ts",
    "test:integration": "vitest run -c vitest.e2e.config.ts",
    "test:ops:unit": "vitest run -c vitest.config.ts src/modules/ops/**/*.test.ts",
    "test:ops:e2e": "vitest run -c vitest.e2e.config.ts src/modules/ops/**/*.e2e.test.ts",
    "test:ops:security": "vitest run -c vitest.security.config.ts src/modules/ops/**/*.security.test.ts",
    "test:ops:rate-limit": "vitest run -c vitest.config.ts src/modules/ops/**/*.rate-limit.test.ts",
    "test:ops": "npm run test:ops:unit && npm run test:ops:e2e && npm run test:ops:security && npm run test:ops:rate-limit",
    "coverage:ops": "vitest run --coverage --include='src/modules/ops/**/*.ts' --exclude='**/*.test.ts' src/modules/ops/**/*.test.ts",
    "contract:admin": "node scripts/admin-contract-check.js",
    "release:guard": "node scripts/reliability-release-guard.js",
    "release:policy-state": "node scripts/release-policy-state.js",
    "test:slo-rules": "node scripts/promtool-test-rules.js",
    "simulate:burnrate": "node scripts/slo-burnrate-simulate.js",
    "edge:drift-check": "node scripts/edge-policy-drift-check.js",
    "docs:runtime-drift-check": "node scripts/docs-runtime-drift-check.js",
    "config:runtime-parity-check": "node scripts/config-runtime-parity-check.js",
    "ops:config-contract-drift-check": "node scripts/ops-config-contract-drift-check.js",
    "ops:config-contract-proposal": "node scripts/ops-config-contract-proposal.js",
    "admin:layer-drift-check": "node scripts/admin-layer-drift-check.js",
    "check:token-contract": "bash scripts/check-token-contract.sh",
    "check:core-drift": "bash scripts/check-core-drift.sh",
    "check:core-purity": "node scripts/check-core-purity.mjs",
    "sync:core": "node scripts/sync-core.mjs",
    "route:discipline-check": "node scripts/route-discipline-check.js",
    "serializer:exposure-check": "node scripts/serializer-exposure-check.js",
    "security:sql-injection-guard": "node scripts/sql-injection-guard.js",
    "test:guardrails": "node --test scripts/route-discipline-check.test.js scripts/serializer-exposure-check.test.js scripts/admin-layer-drift-check.test.js scripts/docs-runtime-drift-check.test.js scripts/config-runtime-parity-check.test.js scripts/ops-config-contract-drift-check.test.js scripts/ops-config-contract-proposal.test.js scripts/route-ast-utils.test.js scripts/sql-injection-guard.test.js && npm run admin:layer-drift-check && npm run docs:runtime-drift-check && npm run config:runtime-parity-check && npm run ops:config-contract-drift-check && npm run security:sql-injection-guard",
    "stress:flash-sale": "node scripts/flash-sale-contention.js",
    "stress:flash-sale:api": "node scripts/flash-sale-contention.js --mode=api",
    "stress:flash-sale:api:matrix": "node scripts/flash-sale-contention.js --mode=api --scenario=hot-normal --seed=42 && node scripts/flash-sale-contention.js --mode=api --scenario=bot-burst --seed=42 && node scripts/flash-sale-contention.js --mode=api --scenario=fairness-abuse --seed=42 && node scripts/flash-sale-contention.js --mode=api --scenario=payment-drop --seed=42",
    "dr:drill:checklist": "node scripts/dr-gameday-checklist.js",
    "dr:drill:checklist:hooked": "node scripts/dr-gameday-hooked.js",
    "dr:drill:stale-check": "node scripts/dr-stale-drill-check.js",
    "dr:failover": "node scripts/dr-failover-run.js",
    "dr:restore": "node scripts/dr-restore-run.js",
    "dr:reconcile": "node scripts/dr-reconcile-validate.js",
    "dr:backup:offsite": "bash scripts/dr-backup-offsite.sh",
    "dr:rto-rpo-report": "node scripts/dr-rto-rpo-report.js",
    "otel:readiness-check": "node scripts/otel-readiness-check.js",
    "parity:scorecard": "node scripts/parity-scorecard.js",
    "ci:reliability-gates": "npm run typecheck && npm run check:token-contract && npm run check:core-drift && npm run check:core-purity && npm run test:unit:coverage && npm run coverage:ratchet && npm run test:e2e && npm run test:security && npm run test:guardrails && npm run route:discipline-check && npm run serializer:exposure-check && npm run security:sql-injection-guard && npm run ops:config-contract-drift-check && npm run build && npm run contract:admin && node scripts/deep-endpoint-smoke.js && npm run release:policy-state && npm run release:guard && npm run test:slo-rules && npm run edge:drift-check && npm run dr:drill:checklist:hooked && npm run dr:drill:stale-check && npm run stress:flash-sale:api:matrix && npm run parity:scorecard",
    "seed:refunded-fixture": "node scripts/seed-refunded-order.js",
    "admin:newuser": "node scripts/admin-newuser.mjs",
    "ops:newuser": "node scripts/ops-newuser.mjs",
    "cleanup:refunded-fixture": "node scripts/cleanup-refunded-fixture.js",
    "prisma:generate:safe": "node scripts/prisma-generate-safe.js",
    "prisma:generate:force": "node scripts/prisma-generate-safe.js --kill-lockers",
    "format": "prettier --write \"{src,queues}/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/fastify": "^7.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/view": "^11.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/client": "^6.19.3",
    "@react-email/render": "^2.0.7",
    "@react-pdf/renderer": "^4.5.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.58.5",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.8.1",
    "ipaddr.js": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "magicast": "0.3.5",
    "prettier": "^3.6.2",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@opentelemetry/exporter-prometheus": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.218.0",
    "@opentelemetry/otlp-exporter-base": "0.218.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.218.0",
    "@opentelemetry/otlp-transformer": "0.218.0",
    "protobufjs": "7.5.8"
  }
}
