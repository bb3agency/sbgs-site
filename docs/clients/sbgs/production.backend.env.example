# Production bootstrap template — copy to VPS backend/.env from vault (never commit filled file)
# See VPS_INPUTS.md and VPS_DEPLOYMENT_PACK.md

NODE_ENV=production
# DO NOT set AUTH_DEV_BYPASS or AUTH_DEV_OTP — development-only; server refuses to start if enabled.
CLIENT_ID=sbgs
BACKEND_PORT=3002
HOST=0.0.0.0
PORT=3002

DATABASE_URL=postgresql://POSTGRES_USER:URL_ENCODED_PASSWORD@host.docker.internal:5432/sbgs
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=sbgs
POSTGRES_PORT=5432

REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379

STOREFRONT_URL=https://srisaibabasweets.com
ADMIN_URL=https://srisaibabasweets.com/admin

JWT_SECRET=
JWT_REFRESH_SECRET=
OPS_DB_ENCRYPTION_KEY=
OPS_DB_ENCRYPTION_KEY_VERSION=1
OPS_COOKIE_SECRET=
AUDIT_ANCHOR_SECRET=
ADMIN_ALERT_EMAIL=
OPS_METRICS_TOKEN=

RESEND_API_KEY=
RESEND_FROM=

# Cloudflare Turnstile — required at boot when NODE_ENV=production (pairs with NEXT_PUBLIC_TURNSTILE_SITE_KEY on storefront)
# Value in VPS_INPUTS.md (gitignored vault)
TURNSTILE_SECRET_KEY=

# Phase 1: do NOT set PAYMENT_PROVIDER or SHIPPING_PROVIDER here — configure via Ops UI.
# Setting a provider mode without matching keys in .env will fail bootstrap checks and app startup.

# Product images (Cloudflare R2) — configure in Ops UI → Product Media (Cloudflare R2), not here.
# After first ops login: MEDIA_STORAGE_PROVIDER=r2 + R2_* keys, then restart API/workers.
PUBLIC_STORE_URL=https://srisaibabasweets.com

ENABLE_VERBOSE_VALIDATION_ERRORS=false
# Storefront coupon on/off: Admin → Coupons toggle (StoreSettings.couponsEnabled).
FEATURE_COUPONS_ENABLED=false
FEATURE_REVIEWS_ENABLED=false
FEATURE_WISHLIST_ENABLED=false
FEATURE_GST_INVOICING_ENABLED=true
FEATURE_RESPONSE_ENVELOPE_ENABLED=false
